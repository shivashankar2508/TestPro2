# TestTrack Pro - Environment Variables
# Copy this file to .env and fill in your values

# ============ Database ============
DATABASE_URL=sqlite:///./testtrack.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/testtrack
# For MySQL: DATABASE_URL=mysql://user:password@localhost:3306/testtrack

# ============ Security ============
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ============ CORS & URLs ============
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001
FRONTEND_URL=http://localhost:3000

# ============ Email Service (Optional) ============
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password
SENDER_NAME=TestTrack Pro

# ============ Google OAuth ============
# Get from: https://console.cloud.google.com/
# Redirect URI: http://localhost:3000/auth/oauth-callback
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============ GitHub OAuth ============
# Get from: https://github.com/settings/developers
# Redirect URI: http://localhost:3000/auth/oauth-callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ============ Application ============
ENV=development
LOG_LEVEL=INFO
APP_NAME=TestTrack Pro
APP_VERSION=1.0.0

# ============ Database Pool (Optional) ============
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600

# ============ Rate Limiting (Optional) ============
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============ Production Settings ============
# Uncomment and configure for production:
# ENV=production
# SECRET_KEY=generate-a-strong-secret-key-here-minimum-32-characters
# DATABASE_URL=postgresql://prod_user:prod_password@prod_host:5432/testtrack
